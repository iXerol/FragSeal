build --announce_rc
build --show_progress_rate_limit=5
build --verbose_failures
build --profile=bazel-profile

build:ci --nokeep_going
build --keep_going

build:release -c opt
build:release --strip=always

common --enable_bzlmod

build:macos --apple_platform_type=macos
build:macos --xcode_version=26

build:swift_linux --features=-swift.symbol_graphs
build:swift_linux --features=-apple.swizzle_absolute_xcttestsourcelocation
build:swift_linux --features=-swift.use_module_wrap
build:swift_linux --features=swift.no_embed_debug_module
build:swift_linux --repo_env=CC=clang
build:swift_linux --repo_env=CXX=clang++
build:swift_linux --repo_env=BAZEL_COMPILER=clang
build:swift_linux --action_env=CC=clang
build:swift_linux --action_env=CXX=clang++


try-import %workspace%/.bazelrc.local
